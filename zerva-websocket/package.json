{
  "name": "@zerva/websocket",
  "type": "module",
  "version": "0.86.1",
  "description": "🌱 Zerva websocket module",
  "author": {
    "name": "Dirk Holtwick",
    "email": "dirk.holtwick@gmail.com",
    "url": "https://holtwick.de"
  },
  "license": "MIT",
  "funding": {
    "type": "GitHub Sponsors ❤",
    "url": "https://github.com/sponsors/holtwick"
  },
  "keywords": [
    "server",
    "typescript",
    "event",
    "websocket",
    "socket",
    "zerva",
    "zeed"
  ],
  "exports": {
    ".": {
      "browser": "./dist/index.browser.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run build:tsdown",
    "build:tsdown": "tsdown src/index.ts src/index.browser.ts ",
    "check": "vue-tsc --noEmit -p ./tsconfig.json",
    "clean": "rm -rf dist www",
    "dbld": "zerva demo/zerva.ts --build && ZEED=* ZEED_COLOR=1 node dist/main.mjs",
    "drun": "ZEED=* ZEED_COLOR=1 zerva demo/zerva.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm test && pnpm run build",
    "release": "pnpm test && pnpm version patch && pnpm build && pnpm publish --no-git-checks",
    "reset": "rm -rf node_modules pnpm-lock.yaml dist dist_www www",
    "start": "pnpm run watch",
    "test": "ZEED=* vitest --globals --run -r src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "watch": "tsdown src/index.ts src/index.browser.ts  --watch"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "@zerva/core": "workspace:*",
    "@zerva/http": "workspace:*",
    "ws": "^8.19.0",
    "zeed": "^1.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@zerva/bin": "workspace:*",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
